# App
DEBUG=true
SECRET_KEY=your-secret-key-here
ALLOWED_HOSTS=localhost,127.0.0.1
CSRF_TRUSTED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000
SECURE_SSL_REDIRECT=false

# Database
DATABASE_URL=postgresql://synco:synco@localhost:5432/synco
POSTGRES_DB=synco
POSTGRES_USER=synco
POSTGRES_PASSWORD=change-me

# Kakao OAuth
KAKAO_CLIENT_ID=
KAKAO_CLIENT_SECRET=
KAKAO_REDIRECT_URI=http://localhost:8000/accounts/kakao/callback/

# Google Drive OAuth files
GOOGLE_CLIENT_SECRET_PATH=.secrets/client_secret.json
GOOGLE_TOKEN_PATH=.secrets/google_token.json

# OpenAI
OPENAI_API_KEY=

# AI - Claude CLI / OpenAI-compatible providers
# Local development defaults to Claude CLI.
# Containerized deployment should prefer an API-backed provider such as openrouter.
LLM_PROVIDER=claude_cli
LLM_API_KEY=
LLM_MODEL=

# Gemini
GEMINI_API_KEY=

# Telegram Bot
TELEGRAM_BOT_TOKEN=
SITE_URL=https://synco.kr
TELEGRAM_WEBHOOK_SECRET=
