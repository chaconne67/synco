# JWT
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080

# OpenAI
OPENAI_API_KEY=

# Web Push VAPID
VAPID_PRIVATE_KEY=
VAPID_PUBLIC_KEY=
