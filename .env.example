# App
DEBUG=true
SECRET_KEY=change-me-in-production

# Database (docker-stack.yml에서 override하므로 로컬 개발용)
DATABASE_URL=postgresql+asyncpg://synco:synco@localhost:5432/synco

# Kakao OAuth (https://developers.kakao.com)
KAKAO_CLIENT_ID=
